# ── Local development ────────────────────────────────────────────────────────
# Leave VITE_API_URL empty. Vite's dev-server proxy (vite.config.js) will
# forward /api/* to localhost:8000 transparently — no CORS headers needed
# because the browser sees everything as the same origin (localhost:5173).
VITE_API_URL=

# ── Production ───────────────────────────────────────────────────────────────
# When frontend and backend are on different domains, set the full API URL:
# VITE_API_URL=https://api.yourcompany.com/api

VITE_APP_NAME="Appreciation Platform"
